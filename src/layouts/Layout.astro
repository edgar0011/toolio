---
import "../styles/global.css";

interface Props {
  title: string;
  currentPath: string;
  bodyClass?: string;
}

const { title, currentPath, bodyClass } = Astro.props;

const appName = __APP_NAME__;
const appVersion = __APP_VERSION__;
const versionComment = `<!-- app name: ${appName} -->\n<!-- app version: ${appVersion} -->`;
---

<!doctype html>
<Fragment set:html={versionComment} />
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Toolio — The all-in-one toolkit for modern teams" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;600&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;600&display=swap" /></noscript>
    <script is:inline>
      // Apply theme class before first paint to prevent flash
      (function() {
        var el = document.documentElement
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        el.classList.remove('dark', 'light')
        el.classList.add(prefersDark ? 'dark' : 'light')
      })()
    </script>
    <title>{title}</title>
  </head>
  <body class={`min-h-screen flex flex-col bg-t-bg text-t-text font-sans antialiased ${bodyClass ?? ""}`}>
    <site-nav current={currentPath}></site-nav>
    <main class="flex-1">
      <slot />
    </main>
    <site-footer></site-footer>

    <script src="../components/molecules/nav/nav.ts"></script>
    <script src="../components/molecules/footer/footer.ts"></script>
  </body>
</html>
